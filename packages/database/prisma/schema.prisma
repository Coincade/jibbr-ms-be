// Shared Prisma schema for all services
// This schema is used by auth-service, messaging-service, and socket-service

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserPresenceStatus {
  available
  away
  in_a_meeting
  do_not_disturb
  custom
}

model User {
  id                       String                      @id @default(cuid())
  name                     String?
  email                    String                      @unique
  password                 String
  password_reset_token     String?
  token_send_at            DateTime?
  email_verified_at         DateTime?
  email_verify_token        String?
  email_verify_token_sent_at DateTime?
  presenceStatus           UserPresenceStatus?         @default(available)
  customStatusMessage      String?                    @db.VarChar(100)
  timezone                 String?                    @db.VarChar(64)
  phone                    String?                    @db.VarChar(32)
  employeeId               String?                    @db.VarChar(64)
  birthday                 DateTime?
  designation              String?                    @db.VarChar(128)
  createdAt                DateTime                    @default(now())
  image                    String?
  updatedAt                DateTime                    @default(now()) @updatedAt
  channels                 Channel[]
  channelMembers           ChannelMember[]
  conversations            ConversationParticipant[]
  conversationReadStatuses ConversationReadStatus[]
  forwardedMessages        ForwardedMessage[]
  members                  Member[]
  messages                 Message[]
  mentions                 MessageMention[]
  reactions                Reaction[]
  userNotifications        UserNotification[]
  notificationPreferences  UserNotificationPreference?
  pushTokens               UserPushToken[]
  workspaces               Workspace[]
  channelInvites           ChannelInvite[]
  userRecents              UserRecent[]
  mutedChannels            UserChannelMute[]
  collaborationRequestsSent WorkspaceCollaborationRequest[] @relation("CollabRequestInitiatorUser")
  collaborationRequestsResponded WorkspaceCollaborationRequest[] @relation("CollabRequestResponderUser")
  collaborationLinksRevoked WorkspaceCollaboration[] @relation("CollabRevokedByUser")
  collaborationPoliciesCreated CollaborationPolicy[]
  collaborationAuditLogs    CollaborationAuditLog[]
  collaborationGroupsCreated CollaborationGroup[]
  collaborationGroupMembershipsInvited CollaborationGroupMembership[] @relation("GroupMembershipInvitedBy")
  collaborationGroupAuditLogs CollaborationGroupAuditLog[]
}

model ChannelInvite {
  id           String      @id @default(cuid())
  channelId    String
  channel      Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  inviteeEmail String
  inviterId    String
  inviter      User        @relation(fields: [inviterId], references: [id])
  token        String      @unique
  status       InviteStatus @default(PENDING)
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime    @default(now())

  @@unique([channelId, inviteeEmail])
  @@index([token])
  @@index([channelId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Workspace {
  id                     String    @id @default(cuid())
  name                   String
  slug                   String    @unique
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @default(now()) @updatedAt
  joinCode               String
  userId                 String
  image                  String?
  isActive               Boolean   @default(true)
  deletedAt              DateTime?
  fileAttachmentsEnabled Boolean   @default(true)
  channels               Channel[]
  members                Member[]
  conversations          Conversation[]
  collaborationRequestsSent WorkspaceCollaborationRequest[] @relation("CollabRequestSenderWorkspace")
  collaborationRequestsReceived WorkspaceCollaborationRequest[] @relation("CollabRequestTargetWorkspace")
  collaborationsAsA      WorkspaceCollaboration[] @relation("CollabWorkspaceA")
  collaborationsAsB      WorkspaceCollaboration[] @relation("CollabWorkspaceB")
  user                   User      @relation(fields: [userId], references: [id])
  userRecents            UserRecent[]
  groupMemberships       CollaborationGroupMembership[]
}

model Channel {
  id                String             @id @default(cuid())
  name              String
  topic             String?            @db.VarChar(120)
  description       String?
  type              ChannelType        @default(PUBLIC)
  isBridgeChannel   Boolean            @default(false)
  collaborationId   String?
  groupId           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  workspaceId       String
  deletedAt         DateTime?
  image             String?
  channelAdminId    String
  channelAdmin      User               @relation(fields: [channelAdminId], references: [id])
  workspace         Workspace          @relation(fields: [workspaceId], references: [id])
  collaboration     WorkspaceCollaboration? @relation(fields: [collaborationId], references: [id])
  group             CollaborationGroup?     @relation(fields: [groupId], references: [id])
  members           ChannelMember[]
  invites           ChannelInvite[]
  forwardedMessages ForwardedMessage[]
  messages          Message[]
  mutedByUsers      UserChannelMute[]

  @@index([collaborationId])
  @@index([groupId])
}

model UserChannelMute {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId])
  @@index([channelId])
}

model Conversation {
  id                String                    @id @unique @default(cuid())
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @default(now()) @updatedAt
  
  // Workspace-specific DMs - each DM conversation belongs to a workspace
  workspaceId       String
  workspace         Workspace                 @relation(fields: [workspaceId], references: [id])
  collaborationId   String?
  collaboration     WorkspaceCollaboration?   @relation(fields: [collaborationId], references: [id])
  groupId           String?
  group             CollaborationGroup?        @relation(fields: [groupId], references: [id])

  participants      ConversationParticipant[]
  readStatuses      ConversationReadStatus[]
  forwardedMessages ForwardedMessage[]
  messages          Message[]
  
  @@index([workspaceId])
  @@index([collaborationId])
  @@index([groupId])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
  conversationId String
  userId         String
  isActive       Boolean      @default(true)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  // Performance indexes for conversation queries
  @@index([userId, isActive])
  @@index([conversationId, isActive])
}

model Message {
  id                String             @id @default(cuid())
  /** Client-generated idempotency key for WS/HTTP retries */
  clientMessageId   String?
  content           String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  channelId         String?
  replyToId         String?
  userId            String
  conversationId    String?
  deletedAt         DateTime?
  isThread          Boolean            @default(false) // true when first reply was sent from thread sidebar (so all clients show thread UI)
  attachments       Attachment[]
  forwardedMessages ForwardedMessage[]
  channel           Channel?           @relation(fields: [channelId], references: [id])
  conversation      Conversation?      @relation(fields: [conversationId], references: [id])
  replyTo           Message?           @relation("MessageReplies", fields: [replyToId], references: [id])
  replies           Message[]          @relation("MessageReplies")
  user              User               @relation(fields: [userId], references: [id])
  mentions          MessageMention[]
  reactions         Reaction[]

  // Performance indexes for fast message queries
  @@index([channelId, createdAt(sort: Desc)])
  @@index([channelId, deletedAt, createdAt(sort: Desc)])
  @@index([conversationId, createdAt(sort: Desc)])
  @@index([conversationId, deletedAt, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([deletedAt])
  @@index([replyToId])
  @@unique([userId, clientMessageId])
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  createdAt    DateTime @default(now())
  messageId    String
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())
  messageId String
  userId    String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
}

model ForwardedMessage {
  id                String        @id @default(cuid())
  createdAt         DateTime      @default(now())
  originalMessageId String
  forwardedByUserId String
  channelId         String?
  conversationId    String?
  channel           Channel?      @relation(fields: [channelId], references: [id])
  conversation      Conversation? @relation(fields: [conversationId], references: [id])
  forwardedBy       User          @relation(fields: [forwardedByUserId], references: [id])
  originalMessage   Message       @relation(fields: [originalMessageId], references: [id])
}

model Member {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  workspaceId String
  userId      String
  role        Role
  isActive    Boolean   @default(true)
  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model ChannelMember {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  channelId   String
  userId      String
  isExternal  Boolean   @default(false)
  isActive    Boolean   @default(true)
  lastReadAt  DateTime?
  unreadCount Int       @default(0)
  channel     Channel   @relation(fields: [channelId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([channelId, userId])
  // Performance indexes for membership checks
  @@index([userId, channelId, isActive])
  @@index([channelId, isActive])
}

model UserNotification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model ConversationReadStatus {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime     @default(now())
  unreadCount    Int          @default(0)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, lastReadAt])
}

model UserNotificationPreference {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  emailNotifications        Boolean  @default(true)
  pushNotifications         Boolean  @default(true)
  desktopNotifications      Boolean  @default(true)
  soundEnabled              Boolean  @default(true)
  mentionNotifications      Boolean  @default(true)
  level                     String   @default("everything") @db.VarChar(32)
  tangentReplies            Boolean  @default(true)
  starredMessagesEvenIfPaused Boolean @default(false)
  newHuddles                Boolean  @default(true)
  scheduleEnabled           Boolean  @default(false)
  scheduleMode              String   @default("weekdays") @db.VarChar(32)
  scheduleDays              Int[]    @default([1, 2, 3, 4, 5])
  scheduleStart             String   @default("09:00") @db.VarChar(8)
  scheduleEnd               String   @default("18:00") @db.VarChar(8)
  muteAll                    Boolean  @default(false)
  soundMessage              String   @default("boop") @db.VarChar(64)
  soundStarred              String   @default("boop") @db.VarChar(64)
  soundHuddle               String   @default("boop") @db.VarChar(64)
  muteHuddleSounds          Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @default(now()) @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MessageMention {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, createdAt])
}

model UserPushToken {
  id         String       @id @default(cuid())
  userId     String
  token      String       @unique
  platform   PushPlatform @default(UNKNOWN)
  deviceName String?
  appVersion String?
  lastUsedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @default(now()) @updatedAt
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
}

enum ChannelType {
  PUBLIC
  PRIVATE
  ANNOUNCEMENT
}

enum Role {
  ADMIN
  MODERATOR
  MEMBER
}

enum NotificationType {
  NEW_MESSAGE
  MENTION
  REACTION
  CHANNEL_INVITE
  WORKSPACE_INVITE
  COLLABORATION_REQUEST
  COLLABORATION_APPROVED
  COLLABORATION_REVOKED
  SYSTEM
}

enum PushPlatform {
  IOS
  ANDROID
  UNKNOWN
}

enum RecentType {
  CHANNEL
  CONVERSATION
}

model UserRecent {
  id           String      @id @default(cuid())
  userId       String
  workspaceId  String
  type         RecentType
  targetId     String
  lastOpenedAt DateTime    @default(now())
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, type, targetId])
  @@index([userId, workspaceId, lastOpenedAt(sort: Desc)])
}

enum WorkspaceCollaborationRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  REVOKED
  EXPIRED
}

enum WorkspaceCollaborationStatus {
  ACTIVE
  REVOKED
}

model WorkspaceCollaborationRequest {
  id                    String                              @id @default(cuid())
  requestingWorkspaceId String
  targetWorkspaceId     String
  requestedByUserId     String
  respondedByUserId     String?
  status                WorkspaceCollaborationRequestStatus @default(PENDING)
  message               String?
  policyTemplate        Json?
  requestedAt           DateTime                            @default(now())
  respondedAt           DateTime?
  createdAt             DateTime                            @default(now())
  updatedAt             DateTime                            @default(now()) @updatedAt
  collaborationId       String?

  requestingWorkspace   Workspace               @relation("CollabRequestSenderWorkspace", fields: [requestingWorkspaceId], references: [id])
  targetWorkspace       Workspace               @relation("CollabRequestTargetWorkspace", fields: [targetWorkspaceId], references: [id])
  requestedBy           User                    @relation("CollabRequestInitiatorUser", fields: [requestedByUserId], references: [id])
  respondedBy           User?                   @relation("CollabRequestResponderUser", fields: [respondedByUserId], references: [id])
  collaboration         WorkspaceCollaboration? @relation("CollaborationRequestLink", fields: [collaborationId], references: [id])
  createdCollaboration  WorkspaceCollaboration? @relation("CollaborationCreatedFromRequest")

  @@index([requestingWorkspaceId, status])
  @@index([targetWorkspaceId, status])
  @@index([requestedByUserId])
}

model WorkspaceCollaboration {
  id                   String                     @id @default(cuid())
  workspaceAId         String
  workspaceBId         String
  status               WorkspaceCollaborationStatus @default(ACTIVE)
  policyId             String
  createdFromRequestId String?                     @unique
  acceptedAt           DateTime?
  revokedAt            DateTime?
  revokedByUserId      String?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @default(now()) @updatedAt

  workspaceA           Workspace                      @relation("CollabWorkspaceA", fields: [workspaceAId], references: [id])
  workspaceB           Workspace                      @relation("CollabWorkspaceB", fields: [workspaceBId], references: [id])
  policy               CollaborationPolicy            @relation(fields: [policyId], references: [id])
  createdFromRequest   WorkspaceCollaborationRequest? @relation("CollaborationCreatedFromRequest", fields: [createdFromRequestId], references: [id])
  revokedBy            User?                          @relation("CollabRevokedByUser", fields: [revokedByUserId], references: [id])
  channels             Channel[]
  conversations        Conversation[]
  auditLogs            CollaborationAuditLog[]
  requests             WorkspaceCollaborationRequest[] @relation("CollaborationRequestLink")

  @@index([workspaceAId, status])
  @@index([workspaceBId, status])
  @@index([policyId])
}

model CollaborationPolicy {
  id                     String                   @id @default(cuid())
  name                   String
  allowExternalDiscovery Boolean                  @default(false)
  allowCrossWorkspaceDm  Boolean                  @default(false)
  allowSharedChannels    Boolean                  @default(false)
  allowFileSharing       Boolean                  @default(false)
  createdByUserId        String
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @default(now()) @updatedAt

  createdBy              User                     @relation(fields: [createdByUserId], references: [id])
  collaborations         WorkspaceCollaboration[]
  groups                 CollaborationGroup[]

  @@index([createdByUserId])
}

model CollaborationAuditLog {
  id              String                 @id @default(cuid())
  collaborationId String
  actorUserId     String
  eventType       String
  eventPayload    Json?
  createdAt       DateTime               @default(now())

  collaboration   WorkspaceCollaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  actor           User                   @relation(fields: [actorUserId], references: [id])

  @@index([collaborationId, createdAt])
  @@index([actorUserId, createdAt])
}

// ─── Collaboration Groups (N-way, e.g. Hirect + sister companies) ────────────

enum CollaborationGroupStatus {
  ACTIVE
  REVOKED
}

enum CollaborationGroupRole {
  OWNER
  MEMBER
}

enum CollaborationGroupMemberStatus {
  INVITED
  ACTIVE
  REVOKED
}

model CollaborationGroup {
  id              String                      @id @default(cuid())
  name            String
  status          CollaborationGroupStatus    @default(ACTIVE)
  policyId        String
  createdByUserId String
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @default(now()) @updatedAt

  policy        CollaborationPolicy            @relation(fields: [policyId], references: [id])
  createdBy     User                           @relation(fields: [createdByUserId], references: [id])
  memberships   CollaborationGroupMembership[]
  channels      Channel[]
  conversations Conversation[]
  auditLogs     CollaborationGroupAuditLog[]

  @@index([status])
}

model CollaborationGroupMembership {
  id              String                         @id @default(cuid())
  groupId         String
  workspaceId     String
  role            CollaborationGroupRole          @default(MEMBER)
  status          CollaborationGroupMemberStatus  @default(INVITED)
  invitedByUserId String?
  respondedAt     DateTime?
  joinedAt        DateTime?
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @default(now()) @updatedAt

  group     CollaborationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  workspace Workspace          @relation(fields: [workspaceId], references: [id])
  invitedBy User?              @relation("GroupMembershipInvitedBy", fields: [invitedByUserId], references: [id])

  @@unique([groupId, workspaceId])
  @@index([groupId, status])
  @@index([workspaceId, status])
}

model CollaborationGroupAuditLog {
  id           String   @id @default(cuid())
  groupId      String
  actorUserId  String
  eventType    String
  eventPayload Json?
  createdAt    DateTime @default(now())

  group CollaborationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  actor User               @relation(fields: [actorUserId], references: [id])

  @@index([groupId, createdAt])
}

