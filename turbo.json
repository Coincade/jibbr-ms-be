{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "concurrency": "15",
  "globalDependencies": [".env"],
  "globalEnv": ["NODE_ENV", "JWT_SECRET", "RATE_LIMIT_MAX", "RATE_LIMIT_WINDOW_MS"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "db:generate": {
      "cache": false,
      "outputs": []
    },
    "db:migrate": {
      "cache": false,
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
