{
  "name": "socket-service",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node ./dist/index.js",
    "server": "nodemon ./dist/index.js",
    "watch": "tsc -w",
    "dev": "concurrently \"npm run watch\" \"npm run server\"",
    "build": "tsc",
    "test": "jest",
    "test:e2e": "jest --runInBand --testPathPattern=\\.e2e\\.test\\.ts$",
    "test:unit": "vitest --run",
    "test:unit:watch": "vitest --watch",
    "test:unit:coverage": "vitest --run --coverage",
    "test:unit:ui": "vitest --ui",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "<rootDir>/tsconfig.json"
        }
      ]
    }
  },
  "dependencies": {
    "@jibbr/auth-middleware": "*",
    "@jibbr/database": "*",
    "@jibbr/shared-utils": "*",
    "@jibbr/logger": "*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "expo-server-sdk": "^4.0.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.7.0",
    "sanitize-html": "^2.17.0",
    "ws": "^8.18.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.7.4",
    "@types/sanitize-html": "^2.16.0",
    "@types/ws": "^8.18.1",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  }
}


