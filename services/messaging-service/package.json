{
  "name": "messaging-service",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node ./dist/index.js",
    "server": "nodemon ./dist/index.js",
    "watch": "tsc -w",
    "dev": "concurrently \"npm run watch\" \"npm run server\"",
    "build": "tsc",
    "test": "jest",
    "test:e2e": "jest --runInBand --testPathPattern=\\.e2e\\.test\\.ts$",
    "test:unit": "vitest --run",
    "test:unit:watch": "vitest --watch",
    "test:unit:coverage": "vitest --run --coverage",
    "test:unit:ui": "vitest --ui",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "cd ../../packages/database && npm run db:generate",
    "db:migrate": "cd ../../packages/database && npm run db:migrate",
    "db:studio": "cd ../../packages/database && npm run db:studio"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "<rootDir>/tsconfig.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "src/config/database.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  },
  "dependencies": {
    "@jibbr/auth-middleware": "*",
    "@jibbr/database": "*",
    "@jibbr/logger": "*",
    "@jibbr/rate-limit": "*",
    "@jibbr/shared-types": "*",
    "@jibbr/shared-utils": "*",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/multer": "^2.0.0",
    "aws-sdk": "^2.1692.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "expo-server-sdk": "^4.0.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "multer": "^2.0.1",
    "redis": "^4.7.0",
    "sanitize-html": "^2.17.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/aws-sdk": "^0.0.42",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.7.4",
    "@types/sanitize-html": "^2.16.0",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "concurrently": "^9.1.2",
    "copyfiles": "^2.4.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  }
}
