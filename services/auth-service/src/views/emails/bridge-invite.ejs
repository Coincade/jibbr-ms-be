<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../partials/email-styles') %>
</head>
<body>
    <div class="email-wrapper">
        <div class="container">
            <p class="greeting">Hello <strong><%= inviteeName %></strong>,</p>
            <p class="body-text"><strong><%= inviterName %></strong> invited you to join the Bridge Channel <strong><%= channelName %></strong> on Jibbr.</p>
            <p class="body-text">Please click the button below to accept the invitation.</p>
            <a href="<%= url %>" target="_blank" class="btn">Accept Invitation</a>

            <p class="note">This link expires in 3 days.</p>

            <p class="url-label">Can't click the button? Copy and paste this URL:</p>
            <p class="url-box"><%= url %></p>

            <div class="footer">
                <%- include('../partials/footer') %>
            </div>
        </div>
    </div>
</body>
</html>
