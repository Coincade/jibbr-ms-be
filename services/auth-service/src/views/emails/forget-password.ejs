<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../partials/email-styles') %>
</head>
<body>
    <div class="email-wrapper">
        <div class="container">
            <p class="greeting">Hello,</p>
            <p class="body-text">Please click the button below to reset your password.</p>
            <a href="<%= url %>" target="_blank" class="btn">Reset Password</a>

            <p class="note">This link expires in 2 hours.</p>

            <p class="url-label">Can't click the button? Copy and paste this URL:</p>
            <p class="url-box"><%= url %></p>

            <div class="footer">
                <%- include('../partials/footer') %>
            </div>
        </div>
    </div>
</body>
</html>