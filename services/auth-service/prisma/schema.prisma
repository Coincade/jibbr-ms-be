// This is your Prisma schema file for Auth Service
// Auth Service owns the User model

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt @default(now())
  password             String
  password_reset_token String?
  token_send_at        DateTime?
  email_verified_at    DateTime?
  email_verify_token   String?
  
  // Note: Relations to messaging models (Workspace, Message, etc.) are managed by messaging-service
  // This service only handles User CRUD operations
}
